{
  "name": "continue-lite",
  "icon": "media/icon.png",
  "author": "huihuimoe, Continue Dev, Inc",
  "version": "1.3.32",
  "repository": {
    "type": "git",
    "url": "https://github.com/continuedev/continue"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "bugs": {
    "url": "https://github.com/continuedev/continue/issues",
    "email": "nate@continue.dev"
  },
  "homepage": "https://continue.dev",
  "qna": "https://github.com/continuedev/continue/issues/new/choose",
  "license": "Apache-2.0",
  "displayName": "Continue Lite - AI Autocomplete & Next Edit",
  "pricing": "Free",
  "description": "Open-source AI autocomplete, next edit, and status bar controls for VS Code.",
  "publisher": "huihuimoe",
  "engines": {
    "vscode": "^1.109.0",
    "node": ">=22.22.0"
  },
  "engine-strict": true,
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "ai",
    "autocomplete",
    "inline completion",
    "next edit",
    "code completion",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "filenames": [
          "config.json",
          ".continuerc.json"
        ],
        "id": "jsonc"
      }
    ],
    "configuration": {
      "title": "Continue",
      "properties": {
        "continue.enableTabAutocomplete": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Continue's tab autocomplete feature. Read our walkthrough to learn about configuration and how to share feedback: [continue.dev › Walkthrough: Tab Autocomplete (beta)](https://docs.continue.dev/features/tab-autocomplete)"
        },
        "continue.enableNextEdit": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Continue's next edit feature. Read our docs to learn about configuration and how to share feedback: [continue.dev › Features › Autocomplete › Next Edit (experimental)](https://docs.continue.dev/features/autocomplete/next-edit)"
        },
        "continue.pauseTabAutocompleteOnBattery": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Pause Continue's tab autocomplete feature when your battery is low."
        },
        "continue.selectedAutocompleteModelTitle": {
          "type": "string",
          "default": "",
          "markdownDescription": "Selected autocomplete model title for Continue's lite autocomplete runtime."
        }
      }
    },
    "commands": [
      {
        "command": "continue.toggleTabAutocompleteEnabled",
        "category": "Continue",
        "title": "Toggle Autocomplete"
      },
      {
        "command": "continue.forceAutocomplete",
        "category": "Continue",
        "title": "Force Autocomplete"
      },
      {
        "command": "continue.openTabAutocompleteConfigMenu",
        "category": "Continue",
        "title": "Open Autocomplete Menu"
      },
      {
        "command": "continue.toggleNextEditEnabled",
        "category": "Continue",
        "title": "Toggle Next Edit"
      },
      {
        "command": "continue.forceNextEdit",
        "category": "Continue",
        "title": "Force Next Edit"
      },
      {
        "command": "continue.acceptJump",
        "category": "Continue",
        "title": "Accept Jump Suggestion"
      },
      {
        "command": "continue.rejectJump",
        "category": "Continue",
        "title": "Reject Jump Suggestion"
      },
      {
        "command": "continue.nextEditWindow.acceptNextEditSuggestion",
        "category": "Continue",
        "title": "Accept Next Edit Suggestion"
      },
      {
        "command": "continue.nextEditWindow.hideNextEditSuggestion",
        "category": "Continue",
        "title": "Hide Next Edit Suggestion"
      }
    ],
    "keybindings": [
      {
        "command": "continue.toggleTabAutocompleteEnabled",
        "mac": "cmd+k cmd+a",
        "key": "ctrl+k ctrl+a",
        "when": "!terminalFocus"
      },
      {
        "command": "continue.forceAutocomplete",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space",
        "when": "editorTextFocus && !editorHasSelection && !editorReadOnly && !inSnippetMode"
      },
      {
        "command": "continue.toggleNextEditEnabled",
        "key": "ctrl+k ctrl+n",
        "mac": "cmd+k cmd+n",
        "when": "editorTextFocus"
      },
      {
        "command": "continue.nextEditWindow.hideNextEditSuggestion",
        "key": "escape",
        "when": "editorTextFocus && nextEditWindowActive && !continue.jumpDecorationVisible"
      },
      {
        "command": "continue.nextEditWindow.acceptNextEditSuggestion",
        "key": "tab",
        "when": "editorTextFocus && nextEditWindowActive && !continue.jumpDecorationVisible"
      },
      {
        "command": "continue.acceptJump",
        "key": "tab",
        "when": "editorTextFocus && continue.jumpDecorationVisible"
      },
      {
        "command": "continue.rejectJump",
        "key": "escape",
        "when": "editorTextFocus && continue.jumpDecorationVisible"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "continue.toggleTabAutocompleteEnabled"
        },
        {
          "command": "continue.forceAutocomplete"
        },
        {
          "command": "continue.openTabAutocompleteConfigMenu"
        },
        {
          "command": "continue.toggleNextEditEnabled"
        },
        {
          "command": "continue.forceNextEdit"
        },
        {
          "command": "continue.acceptJump"
        },
        {
          "command": "continue.rejectJump"
        },
        {
          "command": "continue.nextEditWindow.acceptNextEditSuggestion"
        },
        {
          "command": "continue.nextEditWindow.hideNextEditSuggestion"
        }
      ]
    }
  },
  "scripts": {
    "esbuild-base": "node scripts/esbuild.js",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "esbuild-notify": "npm run esbuild-base -- --sourcemap --notify",
    "esbuild:visualize": "esbuild-visualizer --metadata ./build/meta.json --filename ./build/stats.html --open",
    "tsc": "tsc -p ./tsconfig.json",
    "tsc:check": "tsc -p ./tsconfig.json --noEmit",
    "tsc-watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint . --ext ts --fix",
    "test": "vitest run",
    "vitest": "vitest run",
    "write-build-timestamp": "node scripts/write-build-timestamp.js",
    "prepackage": "node scripts/prepackage.js",
    "package": "node scripts/package.js",
    "package:pre-release": "node scripts/package.js --pre-release",
    "e2e:compile": "tsc -p ./tsconfig.e2e.json",
    "e2e:create-storage": "mkdir -p ./e2e/storage",
    "e2e:get-chromedriver": "node scripts/extest-download.js get-chromedriver",
    "e2e:get-vscode": "node scripts/extest-download.js get-vscode",
    "e2e:sign-vscode": "codesign --entitlements entitlements.plist --deep --force -s - './e2e/storage/Visual Studio Code.app'",
    "e2e:copy-vsix": "chmod +x ./e2e/get-latest-vsix.sh && bash ./e2e/get-latest-vsix.sh",
    "e2e:install-vsix": "node scripts/install-e2e-vsix.js",
    "e2e:install-extensions": "node scripts/install-e2e-extensions.js",
    "e2e:test": "node scripts/run-e2e-tests.cjs",
    "e2e:clean": "rm -rf ./e2e/_output ./e2e/storage",
    "e2e:all": "npm run package && npm run e2e:compile && npm run e2e:create-storage && npm run e2e:get-chromedriver && npm run e2e:get-vscode && npm run e2e:sign-vscode && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && CONTINUE_GLOBAL_DIR=e2e/test-continue npm run e2e:test && npm run e2e:clean",
    "e2e:all-non-mac": "npm run package && npm run e2e:compile && npm run e2e:create-storage && npm run e2e:get-chromedriver && npm run e2e:get-vscode && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && CONTINUE_GLOBAL_DIR=e2e/test-continue npm run e2e:test && npm run e2e:clean",
    "e2e:recompile-extension": "npm run package && npm run e2e:compile && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && CONTINUE_GLOBAL_DIR=e2e/test-continue npm run e2e:test && npm run e2e:clean",
    "e2e:quick": "npm run e2e:compile && npm run e2e:ci:download && CONTINUE_GLOBAL_DIR=e2e/test-continue npm run e2e:test && npm run e2e:clean",
    "e2e:ci:download": "npm run e2e:create-storage && npm run e2e:get-chromedriver && npm run e2e:get-vscode",
    "e2e:ci:run": "npm run e2e:compile && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && CONTINUE_GLOBAL_DIR=e2e/test-continue npm run e2e:test",
    "e2e:ci:run-yaml": "npm run e2e:compile && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && CONTINUE_GLOBAL_DIR=e2e/test-continue-yaml npm run e2e:test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/vscode": "1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "^3.7.1",
    "chai": "^6.2.2",
    "esbuild": "^0.27.3",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^8.57.1",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vscode-extension-tester": "^8.22.1"
  },
  "dependencies": {
    "core": "file:../../core",
    "lru-cache": "^11.2.6",
    "minisearch": "^7.2.0",
    "monaco-vscode-textmate-theme-converter": "^0.1.7",
    "ncp": "^2.0.0",
    "node-machine-id": "^1.1.12",
    "svg-builder": "^3.0.4",
    "systeminformation": "^5.31.3"
  }
}
